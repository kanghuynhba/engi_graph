# Database
DATABASE_URL=sqlite:///./data/engigraph.db

# Vector store
# Current factory defaults to the in-memory vector store.
# qdrant/chroma settings may need implementation wiring before use.
VECTOR_STORE=in_memory
QDRANT_URL=http://localhost:6333

# Embeddings
# Use "dummy" for local development without model downloads.
# Use "local" to load EMBEDDER_MODEL through sentence-transformers.
EMBEDDER=dummy
EMBEDDER_MODEL=BAAI/bge-m3
MAX_EMBEDDING_WORKERS=2

# LLM
# The current factory uses the dummy LLM client by default.
LLM_PROVIDER=dummy
LLM_MODEL=dummy
OPENAI_API_KEY=

# HTTP fetching
HTTP_VERIFY_SSL=true

# Ingestion concurrency
MAX_ARTICLE_WORKERS=5
MAX_DB_WRITERS=1
